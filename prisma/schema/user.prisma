model User {
    id           String     @id @default(uuid())
    name         String?
    email        String     @unique
    password     String
    phone        String?
    profileImage String?
    address      String?
    role         Role       @default(TENANT)
    status       UserStatus @default(ACTIVE)
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt

    // Landlord relations
    properties      Property[]       @relation("LandlordProperties")
    landlordRequest LandlordRequest?

    // Tenant relations
    rentalRequests RentalRequest[] @relation("TenantRentalRequests")
    reviews        Review[]        @relation("TenantReviews")

    @@map("users")
}
